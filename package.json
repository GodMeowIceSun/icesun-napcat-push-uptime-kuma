{
  "name": "icesun-napcat-push-uptime-kuma",
  "plugin": "IceSunNapCat被动推送UptimeKuma插件",
  "version": "1.0.0-SNAPSHOT",
  "type": "module",
  "main": "index.mjs",
  "description": "支持定时发送 Uptime Kuma push 请求，包含当前 NapCat 状态",
  "author": "GodMeowIceSun(icesun@icesun.cn)",
  "license": "MIT",
  "keywords": [
    "napcat",
    "plugin",
    "qq",
    "UptimeKuma"
  ],
  "napcat": {
    "tags": [
      "工具", "监控"
    ],
    "minVersion": "4.14.0",
    "homepage": "https://github.com/GodMeowIceSun/icesun-napcat-push-uptime-kuma"
  },
  "dependencies": {
    "napcat-types": "0.0.16"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "napcat-plugin-debug-cli": "^1.2.8",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "ws": "^8.19.0"
  },
  "scripts": {
    "build": "vite build",
    "build:webui": "cd src/webui && pnpm install && pnpm run build",
    "dev:webui": "cd src/webui && pnpm run dev",
    "watch": "vite build --watch",
    "dev": "vite build --watch",
    "push": "vite build",
    "deploy": "vite build",
    "typecheck": "tsc --noEmit"
  }
}